APP_NAME=MD-ADSS
DEBUG=true

# ── AWS Credentials ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# ── Amazon Nova 2 Lite — Bedrock Converse API ──────────────────────────────
NOVA_LITE_MODEL_ID=amazon.nova-2-lite-v1:0

# ── Bedrock Agent — Nova Act + Nova Forge orchestration ───────────────────
# NOVA_AGENT_ID: Your 10-char Agent ID from the Bedrock console agent overview page
# NOVA_AGENT_ALIAS_ID: The alias ID shown on the same page (yours is below)
NOVA_AGENT_ID=your-agent-id-here
NOVA_AGENT_ALIAS_ID=PLLSBPKVUS

# ── Simulation ─────────────────────────────────────────────────────────────
LOG_GENERATION_INTERVAL=2.0
THREAT_DETECTION_INTERVAL=5.0
THREAT_DETECTION_INTERVAL=5.0
