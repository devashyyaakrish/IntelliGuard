APP_NAME=MD-ADSS
DEBUG=true

# AWS Credentials — add yours here to enable real Nova model calls
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ✅ Amazon Nova 2 Lite (Converse API) — configured for your model ID
NOVA_LITE_MODEL_ID=amazon.nova-2-lite-v1:0

# Bedrock Agent — Nova Act + Nova Forge (add your agent ID when available)
NOVA_AGENT_ID=
NOVA_AGENT_ALIAS_ID=PLLSBPKVUS

# Simulation settings
LOG_GENERATION_INTERVAL=2.0
THREAT_DETECTION_INTERVAL=5.0
